PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gly_vtu

JWT_SECRET=change_this_secret
JWT_ADMIN_SECRET=change_this_admin_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=14
COOKIE_REFRESH=true

# Optional CORS list (comma separated). Leave empty to allow all.
CORS_ORIGIN=

# SMTP for emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@glyvtu.ng
EMAIL_LOGO_URL=
BRAND_URL=
SUPPORT_URL=
PRIVACY_URL=
TERMS_URL=

OTP_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5

# Optional admin seed (use bcrypt hash for password)
ADMIN_SEED_EMAIL=admin@glyvtu.ng
ADMIN_SEED_PASSWORD_HASH=
